# ── Required ───────────────────────────────────────────────────────────────────

# Google Gemini API key (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key


# MongoDB Atlas connection string

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/resume-builder

# Clerk session JWT verification.
# Usually no extra Clerk backend env is needed because the backend derives the
# JWKS URL from the Clerk token issuer. Set these only for custom templates/domains.
CLERK_JWT_ISSUER=
CLERK_JWKS_URL=
CLERK_JWT_AUDIENCE=
# ── Optional ───────────────────────────────────────────────────────────────────

# Google OAuth 2.0 (only needed if enabling Google sign-in)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
